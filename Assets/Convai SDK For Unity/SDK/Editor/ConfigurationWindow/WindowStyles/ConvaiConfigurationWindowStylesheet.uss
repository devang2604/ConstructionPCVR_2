.nav-bar-btn {
    margin: 0 0 12px;
    padding-left: 14px;
    padding-right: 14px;
    color: rgb(209, 250, 229);
    background-color: rgb(45, 106, 79);
    border-left-width: 0;
    border-right-width: 0;
    border-top-width: 0;
    border-bottom-width: 0;
    border-radius: 6px;
    font-size: 14px;
    -unity-text-align: middle-left;
    scale: 0.95 0.95;
    transform-origin: left;
}

.nav-bar-btn:hover {
    margin: 0 0 12px;
    padding-left: 14px;
    padding-right: 14px;
    color: rgb(11, 96, 73);
    background-color: rgb(255, 255, 255);
    border-radius: 6px;
    font-size: 14px;
    -unity-font-style: bold;
    transition-duration: 0.1s;
    translate: 0 0;
    scale: 1 1;
    transform-origin: left;
}

.nav-bar-btn--active {
    margin: 0 0 12px;
    padding-left: 14px;
    padding-right: 14px;
    color: rgb(255, 255, 255);
    background-color: rgb(82, 183, 136);
    border-radius: 6px;
    font-size: 14px;
    -unity-font-style: bold;
    transition-duration: 0.1s;
    translate: 0 0;
    scale: 1 1;
    transform-origin: right;
}

.convai-logo {
    flex-grow: 0;
    background-color: rgba(0, 0, 0, 0);
    -unity-background-scale-mode: scale-to-fit;
    flex-shrink: 0;
    height: 70px;
    margin-bottom: 16px;
}

.nav-bar {
    flex-grow: 0;
    background-color: rgb(11, 96, 73);
    flex-shrink: 1;
    min-width: 200px;
    width: 260px;
    height: 100%;
    padding: 4px 24px 12px 24px;
}

.content-container {
    flex-grow: 1;
    background-color: rgb(245, 245, 245);
    padding: 5px 10px;
}

/* Scrollbar: thumb only, no track. Default: theme dark green; hover: theme active green */
.content-container .unity-scroller--vertical {
    width: 10px;
    background-color: transparent !important;
}

.content-container .unity-scroller--vertical > .unity-slider,
.content-container .unity-scroller--vertical:hover > .unity-slider,
.content-container .unity-scroller--vertical > .unity-slider:hover {
    width: 10px;
    min-width: 10px;
    background-color: transparent !important;
}

.content-container .unity-scroller--vertical .unity-base-slider__tracker,
.content-container .unity-scroller--vertical:hover .unity-base-slider__tracker,
.content-container .unity-scroller--vertical .unity-base-slider__tracker:hover {
    background-color: transparent !important;
    border-width: 0;
}

.content-container .unity-scroller--vertical .unity-base-slider__dragger {
    width: 6px;
    border-radius: 3px;
    background-color: rgb(45, 106, 79);
    left: 2px;
}

.content-container .unity-scroller--vertical:hover .unity-base-slider__dragger {
    background-color: rgb(82, 183, 136);
}

.content-container .unity-scroller--vertical > .unity-repeat-button {
    display: none;
}

.section-card {
    display: none;
    border-width: 1px;
    border-color: rgba(0, 0, 0, 0.1);
    background-color: rgb(243, 244, 246);
    border-radius: 6px;
    padding: 8px 24px;
    flex-grow: 1;
}

.header {
    font-size: 24px;
    -unity-font-style: bold;
    color: rgb(31, 41, 55);
    margin-bottom: 6px;
}

.mb-4 {
    margin-bottom: 16px;
    color: rgb(58, 84, 78);
    white-space: normal;
}

.mb-2 {
    color: rgb(67, 67, 67);
    white-space: normal;
}

.bold {
    -unity-font-style: bold;
}

.subheader {
    -unity-font-style: bold;
    font-size: 18px;
    border-width: 0 0 2px 0;
    border-color: rgb(209, 213, 219);
    color: rgb(9, 97, 72);
    padding-bottom: 4px;
    margin-bottom: 6px;
    margin-left: 0;
}

.button {
    background-color: rgb(11, 96, 73);
    border-radius: 6px;
    border-width: 2px;
    border-color: transparent;
    -unity-font-style: bold;
    color: white;
    transition-duration: 0.1s;
}

.button:hover {
    color: white;
    background-color: rgb(82, 183, 136);
    border-color: rgb(82, 183, 136);
}

.padding-medium {
    padding: 8px 12px;
}

.card {
    background-color: white;
    border-radius: 6px;
    padding: 12px;
    margin-bottom: 8px;
    border-width: 1px;
    border-color: rgb(229, 231, 235);
}

.label {
    font-size: 16px;
    -unity-font-style: bold;
    color: rgb(45, 106, 79);
    margin: 0 0 4px;
    padding: 0;
}

.helper-text {
    font-size: 14px;
    color: rgb(107, 114, 128);
    margin: 4px 0 0;
    padding: 0;
}

.unity-base-field {
    margin: 0;
}

.unity-text-field #unity-text-input {
    background-color: rgb(255, 255, 255);
    border-width: 2px;
    border-color: rgb(209, 213, 219);
    border-radius: 6px;
    padding: 10px 14px;
    margin: 0;
    font-size: 15px;
    color: rgb(51, 51, 51);
}

.unity-text-field #unity-text-input:hover {
    border-color: rgb(156, 163, 175);
}

.unity-text-field #unity-text-input:focus {
    border-color: rgb(9, 94, 56);
}

.textarea {
    min-height: 120px;
}

.btn-medium {
    font-size: 12px;
}

.m-p-zero {
    margin: 0;
    padding: 0;
}

.margin-small {
    margin: 6px 0;
}

.margin-medium {
    margin: 12px 8px;
}

.usage-bar {
    margin: 6px 0;
}

.usage-bar .unity-progress-bar__background {
    background-color: rgb(229, 231, 235);
    border-radius: 6px;
}

.usage-bar .unity-progress-bar__container {
    background-color: rgb(229, 231, 235);
    border-radius: 6px;
    border-top-left-radius: 6px;
    border-bottom-left-radius: 6px;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
}

.usage-bar .unity-progress-bar__progress {
    background-color: rgb(45, 106, 79);
    border-radius: 3px;
    border-top-left-radius: 5px;
    border-bottom-left-radius: 5px;
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
}

.root {
    flex-grow: 1;
    background-color: rgba(0, 0, 0, 0);
    flex-direction: row;
}

.button-small {
    padding: 8px 12px;
    font-size: 12px;
    background-color: rgb(11, 96, 73);
    border-radius: 6px;
    border-width: 2px;
    border-color: transparent;
    -unity-font-style: bold;
    color: white;
    transition-duration: 0.1s;
}

.button-small:hover {
    color: white;
    background-color: rgb(82, 183, 136);
    border-color: rgb(82, 183, 136);
}

.button-small:active {
    background-color: rgb(45, 106, 79);
}

.changelog-section {
    font-size: 16px;
    -unity-font-style: bold;
    color: rgb(33, 150, 243);
    margin-top: 10px;
    margin-bottom: 5px;
}

.changelog-item {
    font-size: 10px;
    margin: 0;
    padding: 0 0 0 20px;
    color: rgb(51, 51, 51);
    white-space: normal;
}

.ltm-table {
    border-radius: 6px;
    border-width: 2px;
    border-color: rgba(0, 0, 0, 0.22);
}

.unity-toggle__checkmark {
    background-color: white;
    border-radius: 6px;
    border-color: rgba(0, 0, 0, 0.22);
    border-width: 2px;
}

.logger-matrix {
    flex-grow: 1;
    min-height: 0;
}

.logger-matrix-hscroll {
    flex-grow: 1;
    min-height: 0;
}

.logger-matrix-hscroll > .unity-scroll-view__content-and-vertical-scroll-container {
    flex-direction: column;
}

.logger-matrix-hscroll > .unity-scroll-view__content-and-vertical-scroll-container > .unity-scroll-view__content-viewport > .unity-scroll-view__content-container {
    min-width: auto;
}

.logger-toolbar {
    border-width: 1px;
    border-color: rgb(209, 213, 219);
    border-radius: 8px;
    background-color: rgb(255, 255, 255);
    padding: 8px 10px 4px 10px;
    margin: 0 0 8px 0;
}

.logger-toolbar-section {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    margin: 0;
    min-height: 34px;
    padding: 6px 0;
}

.logger-toolbar-section--levels {
    border-bottom-width: 1px;
    border-bottom-color: rgba(209, 213, 219, 0.7);
}

.logger-toolbar-section--toggles {
    border-bottom-width: 1px;
    border-bottom-color: rgba(209, 213, 219, 0.7);
}

.logger-toolbar-section--actions {
    justify-content: flex-start;
}

.logger-toolbar-title {
    font-size: 15px;
    -unity-font-style: bold;
    color: rgb(20, 66, 47);
    margin: 0;
    margin-right: 10px;
}

.logger-toolbar-segmented {
    flex-direction: row;
    margin-left: 2px;
}

.logger-toolbar-chip {
    margin: 0;
    padding: 3px 12px;
    min-height: 24px;
    border-width: 1px;
    border-color: rgb(209, 213, 219);
    border-radius: 0;
    background-color: rgb(255, 255, 255);
    color: rgb(31, 41, 55);
    font-size: 12px;
}

.logger-toolbar-chip--first {
    border-top-left-radius: 6px;
    border-bottom-left-radius: 6px;
    border-right-width: 0;
}

.logger-toolbar-chip--middle {
    border-right-width: 0;
}

.logger-toolbar-chip--last {
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
}

.logger-toolbar-chip:hover {
    border-color: rgb(156, 163, 175);
    background-color: rgb(249, 250, 251);
}

.logger-toolbar-chip--selected {
    background-color: rgb(11, 96, 73);
    border-color: rgb(11, 96, 73);
    color: rgb(255, 255, 255);
    -unity-font-style: bold;
}

.logger-toolbar-toggle {
    min-width: 190px;
    margin: 0 16px 0 0;
}

.logger-toolbar-label {
    font-size: 12px;
    -unity-font-style: bold;
    color: rgb(31, 41, 55);
    margin: 0 8px 0 0;
}

.logger-toolbar-popup {
    min-width: 120px;
    margin: 0 8px 0 0;
}

.logger-toolbar-popup .unity-base-field__input {
    border-width: 1px;
    border-color: rgb(209, 213, 219);
    border-radius: 6px;
    background-color: rgb(255, 255, 255);
}

.logger-toolbar-action {
    margin: 0 8px 0 0;
}

.logger-toolbar-action-reset {
    background-color: rgb(20, 66, 47);
}

.logger-toolbar-action-reset:hover {
    background-color: rgb(45, 106, 79);
    border-color: rgb(45, 106, 79);
}

.logger-filter-toggle {
    flex-direction: row;
    margin-left: auto;
    border-width: 1px;
    border-color: rgb(209, 213, 219);
    border-radius: 6px;
    overflow: hidden;
}

.logger-filter-toggle-button {
    margin: 0;
    border-width: 0;
    border-radius: 0;
    background-color: rgb(243, 244, 246);
    color: rgb(55, 65, 81);
    padding: 4px 8px;
    min-height: 22px;
    font-size: 11px;
}

.logger-filter-toggle-button--selected {
    background-color: rgb(11, 96, 73);
    color: rgb(255, 255, 255);
    -unity-font-style: bold;
}

.logger-matrix-header {
    flex-direction: row;
    border-width: 1px;
    border-color: rgb(209, 213, 219);
    border-radius: 6px;
    background-color: rgb(243, 244, 246);
    margin: 0 0 6px 0;
}

.logger-matrix-rows {
    margin: 0;
}

.logger-matrix-row {
    flex-direction: row;
    align-items: center;
    border-width: 1px;
    border-color: rgb(229, 231, 235);
    border-radius: 6px;
    background-color: rgb(255, 255, 255);
    margin: 0 0 6px 0;
}

.logger-matrix-cell {
    margin: 0;
    padding: 6px 8px;
    -unity-text-align: middle-center;
    justify-content: center;
    align-items: center;
    border-radius: 0;
    border-width: 0;
}

.logger-matrix-header-cell {
    -unity-font-style: bold;
    color: rgb(55, 65, 81);
    font-size: 11px;
}

.logger-matrix-cell--category {
    min-width: 160px;
    max-width: 160px;
    flex-shrink: 0;
    -unity-text-align: middle-left;
    justify-content: flex-start;
}

.logger-matrix-cell--effective {
    min-width: 150px;
    max-width: 150px;
    flex-shrink: 0;
    -unity-text-align: middle-left;
    justify-content: flex-start;
}

.logger-matrix-cell--option {
    min-width: 72px;
    max-width: 72px;
    flex-shrink: 0;
    padding: 3px 4px;
    margin-right: 4px;
}

.logger-matrix-cell--option-last {
    margin-right: 0;
}

.logger-matrix-option {
    border-width: 1px;
    border-color: rgb(209, 213, 219);
    border-radius: 6px;
    background-color: rgb(255, 255, 255);
    color: rgb(31, 41, 55);
    font-size: 11px;
    min-height: 24px;
    padding: 0 6px;
}

.logger-matrix-option:hover {
    border-color: rgb(156, 163, 175);
    background-color: rgb(249, 250, 251);
}

.logger-matrix-cell--selected {
    background-color: rgb(11, 96, 73);
    border-color: rgb(11, 96, 73);
    color: rgb(255, 255, 255);
    -unity-font-style: bold;
}

.logger-category-label {
    -unity-font-style: bold;
    color: rgb(20, 66, 47);
    font-size: 12px;
    margin: 0;
}

.logger-effective-badge {
    flex-direction: row;
    align-items: center;
}

.logger-effective-dot {
    width: 8px;
    min-width: 8px;
    height: 8px;
    border-radius: 4px;
    margin-right: 6px;
    background-color: rgb(107, 114, 128);
}

.logger-effective-dot--off {
    background-color: rgb(156, 163, 175);
}

.logger-effective-dot--error {
    background-color: rgb(220, 38, 38);
}

.logger-effective-dot--warning {
    background-color: rgb(217, 119, 6);
}

.logger-effective-dot--info {
    background-color: rgb(37, 99, 235);
}

.logger-effective-dot--debug {
    background-color: rgb(124, 58, 237);
}

.logger-effective-dot--trace {
    background-color: rgb(5, 150, 105);
}

.logger-effective-text {
    color: rgb(75, 85, 99);
    font-size: 11px;
    margin: 0;
}

.logger-scroll-region {
    flex-grow: 1;
    min-height: 290px;
    border-width: 1px;
    border-color: rgb(229, 231, 235);
    border-radius: 8px;
    background-color: rgb(248, 250, 252);
    padding: 6px;
}

.server-animation-card {
    min-width: 160px;
    width: 200px;
    height: 200px;
    flex-shrink: 0;
    margin: 5px;
    padding: 0;
    border-radius: 6px;
    border-width: 2px;
    background-color: white;
}

.server-animation-card > Image {
    width: 100%;
    height: 80%;
    -unity-background-scale-mode: scale-and-crop;
    margin: 0;
    padding: 0;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}

.server-animation-card-label {
    margin: 0;
    flex-grow: 1;
    -unity-text-align: middle-left;
    padding: 0 5px;
    text-overflow: ellipsis;
    overflow: hidden;
    font-size: 12px;
    color: rgb(20, 66, 47);
    -unity-font-style: bold;
}

.dashboard-card {
    margin-bottom: 12px;
}

/* Account section top row: two cards side by side, wrap on narrow windows */
.account-top-row {
    flex-direction: row;
    flex-wrap: wrap;
    margin-bottom: 10px;
}

.account-details-card {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 260px;
}

.account-api-key-card {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 260px;
    max-width: 380px;
}

.api-key-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 8px;
    min-width: 0;
}

.api-key-field {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 0;
    font-size: 14px;
    overflow: hidden;
}

.api-key-field #unity-text-input {
    min-width: 0;
}

/* Server animation nav row: buttons wrap on narrow windows */
.server-anim-nav-row {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    margin-top: 10px;
    margin-bottom: 10px;
}

.server-anim-nav-row > * {
    margin-right: 6px;
    margin-bottom: 6px;
}

.server-anim-nav-row > .button {
    flex-grow: 1;
    min-width: 100px;
}

/* LTM action row: buttons wrap on narrow windows */
.ltm-action-row {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    margin-top: 6px;
    margin-bottom: 6px;
}

.ltm-action-row > * {
    margin-right: 6px;
    margin-bottom: 6px;
}

.welcome-body-text {
    white-space: normal;
}

.welcome-action-row {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
}

.welcome-action-button {
    margin: 0 8px 8px 0;
}

.contact-link-row {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
}

.contact-link-button {
    margin: 0 8px;
}

.setup-health-list {
    margin-top: 6px;
}

.setup-health-row {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin: 0 0 2px 0;
}

.setup-health-name {
    font-size: 13px;
    color: rgb(31, 41, 55);
    margin: 0;
}

.setup-health-status {
    font-size: 10px;
    -unity-font-style: bold;
    border-radius: 3px;
    border-width: 1px;
    min-width: 68px;
    padding: 2px 6px;
    margin: 0;
    -unity-text-align: middle-center;
}

.setup-health-status--healthy {
    background-color: rgb(209, 250, 229);
    border-color: rgb(82, 183, 136);
    color: rgb(6, 95, 70);
}

.setup-health-status--warning {
    background-color: rgb(254, 243, 199);
    border-color: rgb(245, 158, 11);
    color: rgb(146, 64, 14);
}

.setup-health-status--blocked {
    background-color: rgb(254, 226, 226);
    border-color: rgb(239, 68, 68);
    color: rgb(153, 27, 27);
}

.setup-health-message {
    margin: 0 0 6px 0;
    font-size: 12px;
    color: rgb(75, 85, 99);
    white-space: normal;
}
